<!DOCTYPE html>
<html>
  <head>
    <title><%= @city.name %> Weather</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <main class="dashboard">
      <section class="dashboard__header">
        <div>
          <p class="eyebrow"><%= @city.country %></p>
          <h1><%= @city.name %></h1>
        </div>
      </section>

      <section class="metric-grid" aria-label="City weather summary">
        <article class="metric-card">
          <span class="metric-card__label">Records</span>
          <strong><%= @record_count %></strong>
        </article>

        <article class="metric-card">
          <span class="metric-card__label">Latest Date</span>
          <strong><%= @latest_recorded_on || "No data" %></strong>
        </article>

        <article class="metric-card">
          <span class="metric-card__label">Timezone</span>
          <strong class="metric-card__compact"><%= @city.timezone %></strong>
        </article>
      </section>

      <section class="content-panel">
        <div class="section-heading">
          <h2>City Details</h2>
          <p>Location metadata used by the Open-Meteo historical weather import.</p>
        </div>

        <dl class="detail-list">
          <div>
            <dt>Country</dt>
            <dd><%= @city.country %></dd>
          </div>
          <div>
            <dt>Latitude</dt>
            <dd><%= number_with_precision(@city.latitude, precision: 4) %></dd>
          </div>
          <div>
            <dt>Longitude</dt>
            <dd><%= number_with_precision(@city.longitude, precision: 4) %></dd>
          </div>
        </dl>
      </section>

      <section class="content-panel weather-records-panel">
        <div class="section-heading">
          <h2>Daily Weather Records</h2>
          <p>Records are sorted newest first so recent imported weather is easiest to scan.</p>
        </div>

        <div class="city-table-wrap">
          <table class="city-table">
            <thead>
              <tr>
                <th>Date</th>
                <th>High</th>
                <th>Low</th>
                <th>Mean</th>
                <th>Precipitation</th>
                <th>Wind</th>
                <th>Code</th>
              </tr>
            </thead>
            <tbody>
              <% @weather_records.each do |record| %>
                <tr>
                  <td><%= record.recorded_on %></td>
                  <td><%= number_with_precision(record.temperature_max, precision: 1) %> C</td>
                  <td><%= number_with_precision(record.temperature_min, precision: 1) %> C</td>
                  <td><%= number_with_precision(record.temperature_mean, precision: 1) %> C</td>
                  <td><%= number_with_precision(record.precipitation_sum, precision: 1) %> mm</td>
                  <td><%= number_with_precision(record.wind_speed_max, precision: 1) %> km/h</td>
                  <td><%= record.weather_code || "N/A" %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </section>
    </main>
  </body>
</html>
