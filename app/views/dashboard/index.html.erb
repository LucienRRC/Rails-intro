<!DOCTYPE html>
<html>
  <head>
    <title>City Weather Explorer</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
    <main class="dashboard">
      <section class="dashboard__header">
        <div>
          <h1>City Weather Explorer</h1>

        </div>
        <nav class="page-tabs" aria-label="Primary navigation">
          <%= link_to "Dashboard", root_path, class: "page-tab page-tab--active" %>
          <%= link_to "Countries", countries_path, class: "page-tab" %>
          <%= link_to "About", about_path, class: "page-tab" %>
        </nav>
      </section>

      <section class="metric-grid" aria-label="Weather data summary">
        <article class="metric-card">
          <span class="metric-card__label">Cities</span>
          <strong><%= @city_count %></strong>
        </article>

        <article class="metric-card">
          <span class="metric-card__label">Weather Records</span>
          <strong><%= @weather_record_count %></strong>
        </article>

        <article class="metric-card">
          <span class="metric-card__label">Latest Date</span>
          <strong><%= @latest_recorded_on || "No data" %></strong>
        </article>
      </section>

      <section class="content-panel">
        <div class="section-heading">
          <h2>Imported Cities</h2>
          <p>Each city links to daily temperature, precipitation, wind, and weather code data in the database.</p>
        </div>

        <%= form_with url: root_path, method: :get, local: true, class: "search-form" do |form| %>
          <%= form.label :q, "Search cities", class: "search-form__label" %>
          <div class="search-form__controls">
            <%= form.search_field :q, value: @query, placeholder: "City or country", class: "search-form__input" %>
            <%= form.select :country,
                            options_for_select([["All countries", ""]] + @countries.map { |country| [country, country] }, @selected_country),
                            {},
                            class: "search-form__select" %>
            <%= form.submit "Search", class: "search-form__button" %>
            <% if @query.present? || @selected_country.present? %>
              <%= link_to "Clear", root_path, class: "search-form__clear" %>
            <% end %>
          </div>
        <% end %>

        <% if @cities.any? %>
          <div class="city-table-wrap">
            <table class="city-table">
              <thead>
                <tr>
                  <th>City</th>
                  <th>Country</th>
                  <th>Timezone</th>
                  <th>Records</th>
                  <th>Latitude</th>
                  <th>Longitude</th>
                </tr>
              </thead>
              <tbody>
                <% @cities.each do |city| %>
                  <tr>
                    <td><%= link_to city.name, city_path(city), class: "table-link" %></td>
                    <td><%= city.country %></td>
                    <td><%= city.timezone %></td>
                    <td><%= city.weather_records.size %></td>
                    <td><%= number_with_precision(city.latitude, precision: 4) %></td>
                    <td><%= number_with_precision(city.longitude, precision: 4) %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <p class="empty-state">No cities match the current search.</p>
        <% end %>
      </section>
    </main>
  </body>
</html>
